# ============================================================
# AgriAgent – Environment Variables Template
# Copy to .env and fill in your values
# ============================================================

# ── Frontend (VITE_ prefix required) ─────────────────────────

# Firebase Web App config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:your_app_id

# Backend API base URL (for development)
VITE_API_BASE_URL=http://localhost:5000/api

# ML Service base URL (for development)
VITE_ML_BASE_URL=http://localhost:8000

# ── Backend ───────────────────────────────────────────────────

# Server port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Firebase Admin SDK (one of the two options below)
FIREBASE_PROJECT_ID=your-project-id
# Option A: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
# Option B: Inline JSON (for CI/CD environments)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# OpenWeather API key (optional — uses mock data if not set)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ML service URL
ML_SERVICE_URL=http://localhost:8000

# ── ML Service (Python) ───────────────────────────────────────

# Flask port
PORT=8000

# Enable debug mode
DEBUG=false
